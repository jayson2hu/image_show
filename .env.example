# === Service ===
APP_ENV=development
PORT=3000

# === Database ===
DB_DRIVER=sqlite
DATABASE_DSN=

# === Redis ===
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=1

# === JWT ===
JWT_SECRET=your-secret-key-change-me

# === Initial Admin ===
# Development defaults to admin@image-show.local / Admin123456 when these are empty.
# Production requires explicit values if you want the service to seed or reset an admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# === Cloudflare R2 ===
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=image-show
R2_PUBLIC_URL=https://cdn.yourdomain.com

# === SMTP ===
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# === Sub2API ===
SUB2API_BASE_URL=http://sub2api:8080
IMAGE_MODEL=gpt-image-2

# === WeChat Login (new-api compatible WeChat Server mode) ===
WECHAT_AUTH_ENABLED=false
WECHAT_SERVER_ADDRESS=
WECHAT_SERVER_TOKEN=
WECHAT_QRCODE_URL=

# === Payment (new-api compatible EPay mode) ===
SERVER_ADDRESS=https://yourdomain.com
PAY_ADDRESS=
EPAY_ID=
EPAY_KEY=
EPAY_PAY_METHODS=alipay,wxpay

# === Captcha (Cloudflare Turnstile) ===
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# === Development ===
MOCK_SUB2API=false
